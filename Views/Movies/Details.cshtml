@model MVC.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<h1>@Model.Title</h1>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-4">Genre</dt>
            <dd class="col-8">@Model.Genre</dd>
            <dt class="col-4">Release Date</dt>
            <dd class="col-8">@Model.ReleaseDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-4">Price</dt>
            <dd class="col-8">@Model.Price.ToString("C")</dd>
        </dl>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>
