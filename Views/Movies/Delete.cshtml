@model MVC.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<h1>Delete Movie</h1>

<h4>Are you sure you want to delete this movie?</h4>
<div class="border rounded p-3 mb-3">
    <dl class="row">
        <dt class="col-4">Title</dt>
        <dd class="col-8">@Model.Title</dd>
        <dt class="col-4">Genre</dt>
        <dd class="col-8">@Model.Genre</dd>
        <dt class="col-4">Release Date</dt>
        <dd class="col-8">@Model.ReleaseDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-4">Price</dt>
        <dd class="col-8">@Model.Price.ToString("C")</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
